{
  "name": "ukps-likec4",
  "version": "0.1.0",
  "private": true,
  "description": "LikeC4 diagrams for UK PharmaScan (UKPS)",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "likec4 start",
    "start": "likec4 start",
    "build": "likec4 build -o dist",
    "validate": "likec4 validate",
    "format": "likec4 format",
    "generate:model": "likec4 gen model -o ./generated/likec4-model.ts",
    "export:png": "likec4 export png -o ./dist/png"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "likec4": "1.53.0",
    "typescript": "^5.9.3"
  }
}
